                  "cards": [
                    {
                      "type": "tile",
                      "name": "Stage On",
                      "icon": "mdi:spotlight-beam",
                      "color": "deep-purple",
                      "tap_action": {
                        "action": "call-service",
                        "service": "switch.turn_on",
                        "target": {
                          "entity_id": [
                            "switch.stage_lights_left",
                            "switch.stage_lights_right",
                            "switch.bar_lights"
                          ]
                        }
                      }
                    },
                    {
                      "type": "tile",
                      "name": "Stage Off",
                      "icon": "mdi:spotlight",
