                      "tap_action": {
                        "action": "call-service",
                        "service": "switch.turn_off",
                        "target": {
                          "entity_id": [
                            "switch.stage_lights_left",
                            "switch.stage_lights_right",
                            "switch.bar_lights",
                            "switch.dmx"
                          ]
